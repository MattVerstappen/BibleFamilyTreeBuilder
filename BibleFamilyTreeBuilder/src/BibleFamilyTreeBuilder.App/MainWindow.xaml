<Window x:Class="BibleFamilyTreeBuilder.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:BibleFamilyTreeBuilder.App.Controls"
        Title="{Binding WindowTitle}"
        Height="820"
        Width="1300"
        MinHeight="680"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Window}"
        TextElement.Foreground="{DynamicResource Brush.TextPrimary}"
        TextElement.FontFamily="Segoe UI"
        Closing="MainWindow_Closing">
    <DockPanel Background="{DynamicResource Brush.Window}">

        <!-- ===================== Menu bar ===================== -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource Brush.Menu}">
            <MenuItem Header="_File">
                <MenuItem Header="New Sample Tree" Command="{Binding NewSampleTreeCommand}" />
                <Separator />
                <MenuItem Header="Save Project" Command="{Binding SaveProjectCommand}" />
                <MenuItem Header="Save As Project…" Command="{Binding SaveAsProjectCommand}" />
                <MenuItem Header="Load Project…" Command="{Binding LoadProjectCommand}" />
                <Separator />
                <MenuItem Header="Create Backup" Command="{Binding CreateBackupCommand}" />
                <MenuItem Header="Open Backups Folder" Command="{Binding OpenBackupsFolderCommand}" />
                <Separator />
                <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="View Ancestors" Command="{Binding ViewAncestorsCommand}" />
                <MenuItem Header="View Descendants" Command="{Binding ViewDescendantsCommand}" />
                <MenuItem Header="View Ancestors + Descendants" Command="{Binding ViewLineageCommand}" />
                <MenuItem Header="Return to Full Tree" Command="{Binding ReturnToFullTreeCommand}" />
                <Separator />
                <MenuItem Header="Fit Tree to View" Command="{Binding FitTreeToViewCommand}" />
                <MenuItem Header="Center Selected" Command="{Binding CenterSelectedCommand}" />
                <Separator />
                <MenuItem Header="Zoom In" Command="{Binding ZoomInCommand}" />
                <MenuItem Header="Zoom Out" Command="{Binding ZoomOutCommand}" />
                <MenuItem Header="Reset View" Command="{Binding ResetViewCommand}" />
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="Check Tree" Command="{Binding CheckTreeCommand}" />
                <MenuItem Header="Manage Generations…" Command="{Binding ManageGenerationsCommand}" />
                <MenuItem Header="Merge People…" Command="{Binding MergePeopleCommand}" />
                <Separator />
                <MenuItem Header="Export Current View as PNG…" Command="{Binding ExportCurrentViewCommand}" />
                <MenuItem Header="Export Full Tree as PNG…" Command="{Binding ExportFullTreeCommand}" />
            </MenuItem>

            <MenuItem Header="_Layout">
                <MenuItem Header="Auto Layout" Command="{Binding AutoLayoutCommand}" />
                <Separator />
                <MenuItem Header="Nudge Up" Command="{Binding NudgeUpCommand}" />
                <MenuItem Header="Nudge Down" Command="{Binding NudgeDownCommand}" />
                <MenuItem Header="Nudge Left" Command="{Binding NudgeLeftCommand}" />
                <MenuItem Header="Nudge Right" Command="{Binding NudgeRightCommand}" />
                <Separator />
                <MenuItem Header="Clear Manual Position" Command="{Binding ClearManualPositionCommand}" />
            </MenuItem>

            <MenuItem Header="_Theme">
                <MenuItem Header="Parchment" Command="{Binding ApplyThemeCommand}" CommandParameter="Parchment" />
                <MenuItem Header="Light" Command="{Binding ApplyThemeCommand}" CommandParameter="Light" />
                <MenuItem Header="Dark" Command="{Binding ApplyThemeCommand}" CommandParameter="Dark" />
                <Separator />
                <MenuItem Header="Customize Theme…" Command="{Binding CustomizeThemeCommand}" />
            </MenuItem>
        </Menu>

        <!-- ===================== Slim toolbar ===================== -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.ToolBar}"
                BorderBrush="{DynamicResource Brush.PanelBorder}"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <DockPanel>
                <Border DockPanel.Dock="Right"
                        Background="{DynamicResource Brush.Inset}"
                        BorderBrush="{DynamicResource Brush.PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12,4"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentViewModeText}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextPrimary}" />
                </Border>
                <StackPanel Orientation="Horizontal">
                    <Button Content="New Sample" Command="{Binding NewSampleTreeCommand}" Margin="0,0,6,0" />
                    <Button Content="Save" Style="{StaticResource PrimaryButton}" Command="{Binding SaveProjectCommand}" Margin="0,0,6,0" />
                    <Button Content="Load" Command="{Binding LoadProjectCommand}" Margin="0,0,6,0" />
                    <Border Width="1" Background="{DynamicResource Brush.PanelBorder}" Margin="8,2" />
                    <Button Content="Fit" Command="{Binding FitTreeToViewCommand}" Margin="0,0,6,0" />
                    <Button Content="Center" Command="{Binding CenterSelectedCommand}" Margin="0,0,6,0" />
                    <Button Content="Zoom −" Command="{Binding ZoomOutCommand}" Margin="0,0,6,0" />
                    <Button Content="Zoom +" Command="{Binding ZoomInCommand}" Margin="0,0,6,0" />
                    <Button Content="Reset View" Command="{Binding ResetViewCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===================== Main content ===================== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource Brush.PanelBorder}"
                    BorderThickness="0,0,1,0"
                    Background="{DynamicResource Brush.Window}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,12,12,12">
                    <StackPanel>

                        <TextBlock Text="Bible Family Tree"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   Margin="2,0,0,12" />

                        <!-- ===== People ===== -->
                        <Expander Header="People" IsExpanded="True" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Search" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                                <ListBox ItemsSource="{Binding SearchResults}"
                                         SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                                         DisplayMemberPath="EffectiveDisplayName"
                                         Height="90"
                                         Margin="0,0,0,10" />

                                <TextBlock Text="All people" Style="{StaticResource FieldLabel}" />
                                <ListBox ItemsSource="{Binding People}"
                                         SelectedItem="{Binding SelectedPerson, Mode=TwoWay}"
                                         DisplayMemberPath="EffectiveDisplayName"
                                         Height="150"
                                         Margin="0,0,0,10" />
                                <UniformGrid Columns="2">
                                    <Button Content="Add Person" Style="{StaticResource PrimaryButton}" Command="{Binding AddPersonCommand}" Margin="0,0,5,0" />
                                    <Button Content="Delete Person" Click="DeletePerson_Click" IsEnabled="{Binding HasSelectedPerson}" Margin="5,0,0,0" />
                                </UniformGrid>
                            </StackPanel>
                        </Expander>

                        <!-- ===== Selected Person ===== -->
                        <Expander Header="Selected Person" IsExpanded="True" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Quick add" Style="{StaticResource FieldLabel}" />
                                <UniformGrid Columns="2" Margin="0,0,0,12">
                                    <Button Content="Add Child" Command="{Binding AddChildCommand}" Margin="0,0,5,6" />
                                    <Button Content="Add Parent" Command="{Binding AddParentCommand}" Margin="5,0,0,6" />
                                    <Button Content="Add Spouse" Command="{Binding AddSpouseCommand}" Margin="0,0,5,6" />
                                    <Button Content="Add Unknown Desc." Command="{Binding AddUnknownDescendantCommand}" Margin="5,0,0,6" />
                                    <Button Content="Add Grouped People" Command="{Binding AddGroupedPeopleCommand}" Margin="0,0,5,0" />
                                </UniformGrid>

                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding SelectedPerson.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                <TextBlock Text="Display name" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding SelectedPerson.DisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                <TextBlock Text="Also known as" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding SelectedAlsoKnownAsText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="58" TextWrapping="Wrap" Margin="0,0,0,8" />

                                <TextBlock Text="Card type" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding CardTypes}"
                                          SelectedItem="{Binding SelectedPerson.CardType, Mode=TwoWay}"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="Generation override" Style="{StaticResource FieldLabel}" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding SelectedGenerationOverrideText, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1"
                                            Content="Latest"
                                            Command="{Binding SetGenerationToLatestCommand}"
                                            ToolTip="Set this person's generation to the latest (bottom) generation in the tree"
                                            Margin="6,0,0,0" />
                                </Grid>

                                <TextBlock Text="Notes" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding SelectedPerson.Notes, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="82" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" />

                                <TextBlock Text="Bible references" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding SelectedBibleReferencesText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="70" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </Expander>

                        <!-- ===== Generation / Time Period ===== -->
                        <Expander Header="Generation / Time Period" Margin="0,0,0,12">
                            <StackPanel>
                                <Border Background="{DynamicResource Brush.Inset}"
                                        BorderBrush="{DynamicResource Brush.PanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedEffectiveGenerationText}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextPrimary}" />
                                        <TextBlock Text="{Binding SelectedGenerationOverrideStatusText}"
                                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Generation title" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding SelectedGenerationLabelTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                <TextBlock Text="Generation notes" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding SelectedGenerationLabelNotes, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="62" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />

                                <Button Content="Clear Generation Label" Command="{Binding ClearGenerationLabelCommand}" />
                            </StackPanel>
                        </Expander>

                        <!-- ===== Name Variants ===== -->
                        <Expander Header="Name Variants / Book References" Margin="0,0,0,12">
                            <StackPanel>
                                <ListBox ItemsSource="{Binding SelectedPersonNameVariants}"
                                         SelectedItem="{Binding SelectedNameVariantItem, Mode=TwoWay}"
                                         DisplayMemberPath="DisplayText"
                                         Height="86"
                                         Margin="0,0,0,10" />

                                <TextBlock Text="Name used" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding NameVariantNameUsedText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                <TextBlock Text="Book" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding NameVariantBookText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                <TextBlock Text="Reference" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding NameVariantReferenceText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                <TextBlock Text="Translation or source" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding NameVariantTranslationOrSourceText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                <TextBlock Text="Variant notes" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding NameVariantNotesText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />

                                <UniformGrid Columns="3" Margin="0,0,0,10">
                                    <Button Content="Add" Command="{Binding AddNameVariantCommand}" Margin="0,0,5,0" />
                                    <Button Content="Save" Command="{Binding SaveNameVariantCommand}" Margin="5,0,5,0" />
                                    <Button Content="Delete" Command="{Binding DeleteNameVariantCommand}" Margin="5,0,0,0" />
                                </UniformGrid>

                                <Border Background="{DynamicResource Brush.Inset}"
                                        BorderBrush="{DynamicResource Brush.PanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10">
                                    <TextBlock Text="{Binding SelectedPersonNameVariantSummary}" Style="{StaticResource InsetText}" />
                                </Border>
                            </StackPanel>
                        </Expander>

                        <!-- ===== Relationships ===== -->
                        <Expander Header="Relationships" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Add relationship" Style="{StaticResource FieldLabel}" />
                                <TextBlock Text="Target person" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding People}"
                                          SelectedItem="{Binding RelationshipTargetPerson, Mode=TwoWay}"
                                          DisplayMemberPath="EffectiveDisplayName"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="Parent kind" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding ParentKinds}"
                                          SelectedItem="{Binding SelectedParentKind, Mode=TwoWay}"
                                          Margin="0,0,0,8" />

                                <Button Content="Add Parent/Child relationship" Command="{Binding AddParentChildRelationshipCommand}" Margin="0,0,0,6" />
                                <Button Content="Add Marriage relationship" Command="{Binding AddMarriageRelationshipCommand}" Margin="0,0,0,14" />

                                <TextBlock Text="Selected person relationships" Style="{StaticResource FieldLabel}" />
                                <ListBox ItemsSource="{Binding SelectedPersonRelationships}"
                                         SelectedItem="{Binding SelectedRelationshipItem, Mode=TwoWay}"
                                         DisplayMemberPath="DisplayText"
                                         Height="116"
                                         Margin="0,0,0,10" />

                                <TextBlock Text="Relationship label" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding RelationshipDisplayLabelText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                <TextBlock Text="Relationship parent kind" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding ParentKinds}"
                                          SelectedItem="{Binding SelectedRelationshipParentKind, Mode=TwoWay}"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="Evidence level" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding EvidenceLevels}"
                                          SelectedItem="{Binding SelectedRelationshipEvidenceLevel, Mode=TwoWay}"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="Relationship Bible references" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding RelationshipBibleReferencesText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="58" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" />

                                <TextBlock Text="Relationship notes" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding RelationshipNotesText, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="70" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />

                                <Button Content="Save Relationship Changes" Style="{StaticResource PrimaryButton}" Command="{Binding SaveRelationshipChangesCommand}" Margin="0,0,0,6" />
                                <Button Content="Delete Selected Relationship" Command="{Binding DeleteRelationshipCommand}" Margin="0,0,0,14" />

                                <TextBlock Text="Relationship summary" Style="{StaticResource FieldLabel}" />
                                <Border Background="{DynamicResource Brush.Inset}"
                                        BorderBrush="{DynamicResource Brush.PanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,10">
                                    <TextBlock Text="{Binding SelectedPersonRelationshipSummary}" Style="{StaticResource InsetText}" />
                                </Border>

                                <TextBlock Text="Marriage connectors are pink. Adopted/legal parent lines are dashed."
                                           Style="{StaticResource SectionHint}" />
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <controls:TreeCanvas x:Name="TreeViewCanvas"
                                 Grid.Column="1"
                                 Project="{Binding DisplayProject}"
                                 SelectedPerson="{Binding SelectedPerson, Mode=TwoWay}"
                                 Zoom="{Binding Zoom, Mode=TwoWay}"
                                 ExportTitle="{Binding CurrentViewModeText}" />
        </Grid>
    </DockPanel>
</Window>
