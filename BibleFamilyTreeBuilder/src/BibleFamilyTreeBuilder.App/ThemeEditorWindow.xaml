<Window x:Class="BibleFamilyTreeBuilder.App.ThemeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customize Theme"
        Height="640"
        Width="640"
        MinHeight="520"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Window}"
        TextElement.Foreground="{DynamicResource Brush.TextPrimary}"
        TextElement.FontFamily="Segoe UI">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Customize Theme"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}" />
            <TextBlock Text="Adjust the colors below. Changes preview live. Save keeps them as your Custom theme; Cancel discards them."
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <TextBlock Text="Start from:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
            <ComboBox x:Name="BaseCombo" Width="180" SelectionChanged="BaseCombo_SelectionChanged" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="{DynamicResource Brush.Panel}"
                BorderBrush="{DynamicResource Brush.PanelBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ColorList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" Margin="2" CornerRadius="6"
                                    Background="{DynamicResource Brush.Inset}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="38" Height="38" CornerRadius="6"
                                            BorderBrush="{DynamicResource Brush.PanelBorder}" BorderThickness="1"
                                            Background="{Binding SwatchBrush}" VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                                   TextWrapping="Wrap" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding Hex, UpdateSourceTrigger=PropertyChanged}" Width="92" HorizontalAlignment="Left" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Slider Minimum="0" Maximum="255" Value="{Binding R}" />
                                        <Slider Minimum="0" Maximum="255" Value="{Binding G}" Margin="0,4,0,0" />
                                        <Slider Minimum="0" Maximum="255" Value="{Binding B}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Reset to base" Click="Reset_Click" Margin="0,0,8,0" />
            <Button Content="Cancel" Width="100" IsCancel="True" Click="Cancel_Click" Margin="0,0,8,0" />
            <Button Content="Save" Style="{StaticResource PrimaryButton}" Width="110" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
